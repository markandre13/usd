{
    "compilerOptions": {
        "target": "es2020",
        "module": "es6",
        "lib": [
            "es2024"
        ],
        "moduleResolution": "node",
        "traceResolution": false,
        "esModuleInterop": true,
        "incremental": true,
        "declaration": true,
        "outDir": "dist",
        "baseUrl": ".",
        "plugins": [
            {
                "transform": "./m13-es-transformer.cjs",
                "after": true,
            }
        ],
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "removeComments": true,
        "experimentalDecorators": true,
        "noImplicitOverride": true,
        "strict": true,
        "strictNullChecks": true,
        "allowJs": false,
        "noImplicitAny": true,
        "sourceMap": true
    },
    "include": [
        "src",
    ]
}